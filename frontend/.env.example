# Frontend build-time config (Vite). Copy to `frontend/.env` to override.

# Base origin for the backend API.
# - WEB build: leave EMPTY. The app uses same-origin "/api/..." (Vite dev proxy
#   locally, serverless functions in production).
# - ANDROID/Capacitor build: set to your deployed backend's absolute origin, so
#   the WebView reaches it. Example:
#     VITE_API_BASE_URL=https://your-app.vercel.app
VITE_API_BASE_URL=
