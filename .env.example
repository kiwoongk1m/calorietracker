# ---------------------------------------------------------------------------
# Food calorie estimator — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Which provider backs each step. Stage 1 ships with "mock" for both, so the
# whole app runs end-to-end with no real API keys. Flip these to the real
# providers in later stages WITHOUT touching any other code.
#   recognition: mock | visionllm        (visionllm = Task B)
#   nutrition:   mock | usda             (usda       = Task C)
RECOGNITION_PROVIDER=mock
NUTRITION_PROVIDER=mock

# Port the backend Express server listens on (frontend dev proxy targets this).
PORT=3001

# --- Real provider credentials (only needed once you flip the providers) ---

# Task B — vision LLM (Anthropic) API key. SERVER-SIDE ONLY. Never expose to the
# browser. Used only when RECOGNITION_PROVIDER=visionllm. ANTHROPIC_API_KEY is
# also accepted as a fallback name.
VISION_LLM_API_KEY=
# Optional: override the vision model. Defaults to claude-haiku-4-5 (cheap + fast,
# ~$0.0025/scan, plenty accurate for dish ID). Set to claude-opus-4-8 for the
# highest accuracy at ~5x the cost.
# VISION_LLM_MODEL=claude-opus-4-8

# Task C — USDA FoodData Central API key (free): https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=
